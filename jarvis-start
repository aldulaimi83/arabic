#!/bin/zsh
# /jarvis-start — Start the Jarvis server

JARVIS_DIR="$HOME/Desktop/sofi"
LOG_DIR="$HOME/.jarvis_logs"
mkdir -p "$LOG_DIR"

# Check if already running
if pgrep -f "jarvis_server.py" > /dev/null; then
  echo "⚡ Jarvis is already running."
  open "http://localhost:5001"
  exit 0
fi

# Start Ollama if not running
if ! pgrep -x "ollama" > /dev/null; then
  echo "🧠 Starting Ollama..."
  ollama serve > "$LOG_DIR/ollama.log" 2>&1 &
  sleep 2
fi

# Start Jarvis server
echo "🚀 Starting Jarvis..."
cd "$JARVIS_DIR"
nohup python3 jarvis_server.py > "$LOG_DIR/jarvis.log" 2>&1 &
sleep 2

if pgrep -f "jarvis_server.py" > /dev/null; then
  echo "✅ Jarvis is online at http://localhost:5001"
  open "http://localhost:5001"
else
  echo "❌ Failed to start. Check $LOG_DIR/jarvis.log"
fi
